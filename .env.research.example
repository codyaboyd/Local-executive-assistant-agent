# Online research profile using a self-hosted FastCRW service.
EXEC_AGENT_ENV=development
EXEC_AGENT_RUNTIME_PROFILE=research-online
EXEC_AGENT_DEVICE=auto
EXEC_AGENT_MODEL_ID=sshleifer/tiny-gpt2
EXEC_AGENT_DATA_DIR=~/.local/share/exec-agent
EXEC_AGENT_WEB_ENABLED=true
FASTCRW_ENABLED=true
FASTCRW_BASE_URL=http://localhost:3002
FASTCRW_API_PREFIX=/v1
FASTCRW_API_KEY=
FASTCRW_PORT=3002
FASTCRW_MAX_RESULTS=5
FASTCRW_ENABLE_SCRAPE=true
FASTCRW_ENABLE_CRAWL=false
FASTCRW_CRAWL_REQUIRES_APPROVAL=true
EXEC_AGENT_MODEL_PRESET=research
EXEC_AGENT_MODEL_AUTO_PULL=false
EXEC_AGENT_MAX_VRAM_GB=16
EXEC_AGENT_GENERAL_MODEL_ID=auto
EXEC_AGENT_CODING_MODEL_ID=auto
EXEC_AGENT_SUMMARY_MODEL_ID=auto
EXEC_AGENT_DOCQA_MODEL_ID=auto
EXEC_AGENT_RESEARCH_MODEL_ID=auto
EXEC_AGENT_TOOL_MODEL_ID=auto
EXEC_AGENT_EMBEDDING_MODEL_ID=auto
EXEC_AGENT_VISION_MODEL_ID=auto
EXEC_AGENT_ALLOWED_DIRS=./workspace,./data,./uploads
EXEC_AGENT_READONLY_DIRS=
EXEC_AGENT_BLOCKED_PATHS=/etc,/root,/home/*/.ssh,/home/*/.gnupg
EXEC_AGENT_MAX_FILE_SIZE_MB=25
