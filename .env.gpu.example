# CUDA profile. Use only on machines where `nvidia-smi` and torch CUDA work.
EXEC_AGENT_ENV=development
EXEC_AGENT_RUNTIME_PROFILE=gpu-fast
EXEC_AGENT_DEVICE=cuda
EXEC_AGENT_MODEL_ID=distilgpt2
EXEC_AGENT_MAX_TOKENS=256
EXEC_AGENT_TEMPERATURE=0.4
EXEC_AGENT_DATA_DIR=~/.local/share/exec-agent
EXEC_AGENT_LOCAL_ONLY=false
EXEC_AGENT_WEB_ENABLED=false
FASTCRW_ENABLED=false
