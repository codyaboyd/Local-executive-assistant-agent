# CPU-only private assistant profile for normal Linux laptops/desktops.
EXEC_AGENT_ENV=development
EXEC_AGENT_RUNTIME_PROFILE=cpu-safe
EXEC_AGENT_DEVICE=cpu
EXEC_AGENT_MODEL_ID=sshleifer/tiny-gpt2
EXEC_AGENT_MAX_TOKENS=128
EXEC_AGENT_TEMPERATURE=0.2
EXEC_AGENT_DATA_DIR=~/.local/share/exec-agent
EXEC_AGENT_LOCAL_ONLY=true
EXEC_AGENT_WEB_ENABLED=false
FASTCRW_ENABLED=false
