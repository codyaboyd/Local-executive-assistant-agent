# Runtime environment: development, staging, production
EXEC_AGENT_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
EXEC_AGENT_LOG_LEVEL=INFO

# Local data directory used by future agent features
EXEC_AGENT_DATA_DIR=~/.local/share/exec-agent

# Runtime profile: cpu-safe, gpu-fast, private-offline, research-online, test-hitl
# private-offline disables web and FastCRW. research-online enables self-hosted
# FastCRW from FASTCRW_BASE_URL. test-hitl enables HITL and requires crawl approval.
EXEC_AGENT_RUNTIME_PROFILE=private-offline
EXEC_AGENT_WEB_ENABLED=false
FASTCRW_ENABLED=false
FASTCRW_PORT=3002
FASTCRW_API_KEY=
FASTCRW_CRAWL_REQUIRES_APPROVAL=false
FASTCRW_BASE_URL=http://localhost:3002
FASTCRW_API_PREFIX=/v1
FASTCRW_ENABLE_CRAWL=false

# Role-specific model selector for <=16GB consumer GPUs and CPU-only mode.
EXEC_AGENT_MODEL_PRESET=default
EXEC_AGENT_MODEL_AUTO_PULL=false
EXEC_AGENT_MAX_VRAM_GB=16
EXEC_AGENT_GENERAL_MODEL_ID=auto
EXEC_AGENT_CODING_MODEL_ID=auto
EXEC_AGENT_SUMMARY_MODEL_ID=auto
EXEC_AGENT_DOCQA_MODEL_ID=auto
EXEC_AGENT_RESEARCH_MODEL_ID=auto
EXEC_AGENT_TOOL_MODEL_ID=auto
EXEC_AGENT_EMBEDDING_MODEL_ID=auto
EXEC_AGENT_VISION_MODEL_ID=auto
EXEC_AGENT_ALLOWED_DIRS=./workspace,./data,./uploads
EXEC_AGENT_READONLY_DIRS=
EXEC_AGENT_BLOCKED_PATHS=/etc,/root,/home/*/.ssh,/home/*/.gnupg
EXEC_AGENT_MAX_FILE_SIZE_MB=25
